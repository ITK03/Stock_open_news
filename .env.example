# 重要度分析に使うLLMプロバイダ。鍵が無ければ "none"(ルールベースのみ)で動作。
# none | gemini | groq | openai | claude
LLM_PROVIDER=none

# Google Gemini 無料枠を使う場合(推奨・無料): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq 無料枠を使う場合: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI を使う場合
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Claude(Anthropic) を使う場合
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Discord 通知(後段)。Webhook URL。
DISCORD_WEBHOOK_URL=

# LLM精査を行う最低スコア閾値(これ未満はルールベース要約のみでLLM呼ばない=無料枠節約)
LLM_MIN_SCORE=50

# このスコア未満の開示は「重要度低」として保存・表示しない(既定0=全件保持。
# 適時開示の取りこぼしを防ぐため、役員人事等の軽微開示もデフォルトで残す)
MIN_SCORE=0

# 保持する最大件数(当日+前日をまるごと取得する運用に合わせて大きめ)
MAX_ITEMS=2000
